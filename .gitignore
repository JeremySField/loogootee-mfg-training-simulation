# ─────────────────────────────────────────────────────────────
# LOOGOOTEE MFG. TRAINING SIMULATION — .gitignore
# Philosophy: keep everything project-related including
# installers, libraries, vendor docs, and firmware archives.
# Only exclude credentials, OS junk, and auto-generated junk.
# ─────────────────────────────────────────────────────────────


# ── CREDENTIALS — ABSOLUTE EXCLUSION ─────────────────────────
# No usernames, passwords, tokens, or keys of any kind
.env
*.env
mosquitto_passwd
passwd
auth.conf
credentials.txt
secrets.txt
*_api_key*
*_password*
*_secret*
*_token*
*_key.txt
*.pem
*.key
*.pfx
*.p12


# ── OS GENERATED JUNK ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db


# ── WINDOWS OFFICE TEMP / LOCK FILES ─────────────────────────
# These are lock files created when a document is open — not real files
~$*.docx
~$*.xlsx
~$*.pptx
~$*.doc
~$*.xls
~$*.ppt


# ── RSLOGIX AUTO-BACKUP FILES ────────────────────────────────
# .RSS and .ACD are the real program files — .bak are auto-generated duplicates
*.bak


# ── VS CODE WORKSPACE ────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json


# ── PYTHON CACHE ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo


# ── NODE MODULES ─────────────────────────────────────────────
# Keep package.json and package-lock.json — exclude the installed modules
node_modules/


# ── EVERYTHING ELSE STAYS ────────────────────────────────────
# Installers, firmware, library packages, vendor documentation,
# IFM AL1590 docs, e!COCKPIT archive, CODESYS libraries,
# EDS/GSD/GSDML/IODD device description files, example projects,
# packet captures, video files, VM images, zip archives —
# all kept intentionally as project reference material.

# Large vendor files - store locally only
*.exe
08_io_link_implementation/ifm_al1590_vendor_docs_programming/Firmware_*
08_io_link_implementation/ifm_al1590_vendor_docs_programming/Startup_Package_AL1x0x*
08_io_link_implementation/ifm_al1590_vendor_docs_programming/Startup_Package_AL1x2x_EIP_PLC_Keyence*
09_io_link_implementation/ifm_al1590_vendor_docs_programming/*.zip
09_io_link_implementation/ifm_al1590_vendor_docs_programming/*.zip.zip